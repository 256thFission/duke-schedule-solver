# Duke Schedule Solver — Backend Environment Variables
# Copy to .env and fill in values

# Comma-separated list of allowed CORS origins
# Local dev:   http://localhost:5173
# Production:  https://yourdomain.netlify.app,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# Number of Uvicorn workers (for Docker deployment)
UVICORN_WORKERS=2
